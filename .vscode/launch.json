{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Nest Framework",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["run", "start:debug"],
      "autoAttachChildProcesses": true,
      "restart": true,
      "sourceMaps": true,
      "stopOnEntry": false,
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}/apps/backend"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Nest",
      "processId": "${command:PickProcess}",
      "port": 9229,
      "sourceMaps": true,
      "restart": true,
      "protocol": "inspector"
    }
  ]
}
