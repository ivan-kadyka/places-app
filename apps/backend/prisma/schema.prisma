generator client {
  provider = "prisma-client"
  output   = "generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Place {
  id           String          @id @default(cuid())
  openMeteoId  Int?            
  name         String
  countryCode  String
  latitude     Float
  longitude    Float
  elevation    Float?
  timezone     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  snapshots    WeatherSnapshot[]

  @@index([name, countryCode])
}

model WeatherSnapshot {
  id         String   @id @default(cuid())
  placeId String
  place   Place @relation(fields: [placeId], references: [id], onDelete: Cascade)
  fetchedAt  DateTime @default(now())
  expiresAt  DateTime
  dailyData  Json

  @@index([placeId, fetchedAt(sort: Desc)])
  @@index([expiresAt])
}
