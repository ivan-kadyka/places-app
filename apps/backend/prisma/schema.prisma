generator client {
  provider = "prisma-client"
  output   = "generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Place {
  id           String          @id @default(cuid())
  name         String
  countryCode  String
  latitude     Float
  longitude    Float
  elevation    Float?
  timezone     String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  daySnapshots WeatherDaySnapshot[]

  @@index([name, countryCode])
}
model WeatherDaySnapshot {
  id         String   @id @default(cuid())
  providerType String
  date DateTime @db.Date
  snapshot  Json

  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  
  placeId String
  place   Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([placeId, updatedAt(sort: Desc)])
}
