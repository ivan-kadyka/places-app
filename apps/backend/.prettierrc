{
  "arrowParent": "avoid",
  "endOfLine": "lf",
  "printWidth": 120,
  "semi": false,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "none",
  "bracketSameLine": true,
  "arrowParens": "avoid",
  "experimentalTernaries": true,
  "plugins": ["prettier-plugin-tailwindcss", "prettier-plugin-prisma"]
}
