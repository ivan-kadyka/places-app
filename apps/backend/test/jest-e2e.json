{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^prisma/generated/client$": "<rootDir>/../prisma/generated/client",
    "^(\\..*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}
